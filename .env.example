# Shared
ENVIRONMENT=dev
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000

# Database (shared Postgres for local dev)
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/yojanamitra

# Redis
REDIS_URL=redis://redis:6379/0

# Auth (JWT)
JWT_SECRET=change-me-in-prod
JWT_ISSUER=yojanamitra-ai
JWT_AUDIENCE=yojanamitra-users
JWT_EXPIRES_MINUTES=60

# Dev bootstrap (optional): create an admin user on startup of user-service
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PHONE=
BOOTSTRAP_ADMIN_PASSWORD=admin12345

# Service discovery (Docker Compose defaults)
USER_SERVICE_URL=http://user-service:8000
SCHEME_SERVICE_URL=http://scheme-service:8000
ELIGIBILITY_SERVICE_URL=http://eligibility-service:8000
CHATBOT_SERVICE_URL=http://chatbot-service:8000
NOTIFICATION_SERVICE_URL=http://notification-service:8000

# LLM (optional)
# LLM_PROVIDER=openai|gemini
LLM_PROVIDER=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
GEMINI_API_KEY=

# WhatsApp Cloud API (optional)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Voice (optional)
# If using OpenAI Whisper via API
OPENAI_WHISPER_MODEL=gpt-4o-mini-transcribe
